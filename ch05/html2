<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>성적</title>
</head>
<body>

<input type="number" id="score" placeholder="점수를 입력하세요">
<button onclick="checkGrade()">확인</button>
<div id="print"></div>

<script>

function checkGrade() {

    let score = document.getElementById("score").value;
    let grade;

    if (score > 100 || score < 0) {
        document.getElementById("print").innerText = "올바른 점수(0~100)를 입력하세요.";
        return;
    }

    switch (Math.floor(score / 10)) {
        case 10:
        case 9:
            grade = "A";
            break;
        case 8:
            grade = "B";
            break;
        case 7:
            grade = "C";
            break;
        case 6:
            grade = "D";
            break;
        default:
            grade = "F";
    }

    document.getElementById("print").innerText = "성적: " + grade;
}

</script>

</body>
</html>